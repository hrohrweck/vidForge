# Model storage paths on host machine
# Change these to customize where models are stored
COMFYUI_MODELS_PATH=../models/comfyui
COMFYUI_OUTPUT_PATH=../models/comfyui-output
OLLAMA_MODELS_PATH=../models/ollama

# Host-mapped port for the ollama container.
# Defaults to a non-standard port (11435) to avoid collisions with a native
# Ollama install on the host (which uses 11434). The container itself still
# listens on 11434 internally, so other compose services keep using
# http://ollama:11434 unchanged.
OLLAMA_PORT=11435
