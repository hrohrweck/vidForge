{
  "1": {
    "inputs": {
      "ckpt_name": "{checkpoint}"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "2": {
    "inputs": {
      "text": "{prompt}",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "inputs": {
      "text": "{negative_prompt}",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Negative)"
    }
  },
  "4": {
    "inputs": {
      "image": "{reference_image_path}"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Reference Image"
    }
  },
  "5": {
    "inputs": {
      "ipadapter_file": "{ip_adapter_model}"
    },
    "class_type": "IPAdapterModelLoader",
    "_meta": {
      "title": "Load IP-Adapter Model"
    }
  },
  "6": {
    "inputs": {
      "clip_name": "{clip_vision_model}"
    },
    "class_type": "CLIPVisionLoader",
    "_meta": {
      "title": "Load CLIP Vision Model"
    }
  },
  "7": {
    "inputs": {
      "clip_vision": ["6", 0],
      "image": ["4", 0]
    },
    "class_type": "CLIPVisionEncode",
    "_meta": {
      "title": "CLIP Vision Encode"
    }
  },
  "8": {
    "inputs": {
      "ipadapter": ["5", 0],
      "clip_vision": ["7", 0],
      "model": ["1", 0],
      "weight": {ip_adapter_strength}
    },
    "class_type": "IPAdapterApply",
    "_meta": {
      "title": "IP-Adapter Apply"
    }
  },
  "9": {
    "inputs": {
      "width": {width},
      "height": {height},
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {
      "title": "Empty Latent Image"
    }
  },
  "10": {
    "inputs": {
      "seed": {seed},
      "steps": 30,
      "cfg": 7.5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["8", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["9", 0]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler"
    }
  },
  "11": {
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "12": {
    "inputs": {
      "filename_prefix": "ip_adapter_output",
      "images": ["11", 0]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image"
    }
  }
}
