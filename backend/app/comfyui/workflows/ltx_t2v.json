{
  "1": {
    "class_type": "LTXVideoModelLoader",
    "inputs": {
      "model": "ltx-2.3-22b-dev.safetensors",
      "precision": "bf16"
    }
  },
  "2": {
    "class_type": "LTXVideoEncodePrompt",
    "inputs": {
      "prompt": "",
      "negative_prompt": ""
    }
  },
  "3": {
    "class_type": "LTXVideoEmptyLatent",
    "inputs": {
      "width": 768,
      "height": 480,
      "frames": 121,
      "batch_size": 1
    }
  },
  "4": {
    "class_type": "LTXVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["2", 1],
      "latent": ["3", 0],
      "seed": 0,
      "steps": 30,
      "cfg": 3.0,
      "scheduler": "euler"
    }
  },
  "5": {
    "class_type": "LTXVideoDecode",
    "inputs": {
      "model": ["1", 0],
      "latent": ["4", 0]
    }
  },
  "6": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["5", 0],
      "fps": 24
    }
  },
  "7": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["6", 0],
      "filename_prefix": "vidforge_ltx_output",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
