# Database
# When running via docker-compose, postgres is bound to 127.0.0.1:5432.
# Set POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB in docker/.env.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER:-vidforge}:${POSTGRES_PASSWORD:-vidforge}@localhost:5432/${POSTGRES_DB:-vidforge}

# Redis
# When running via docker-compose, redis is bound to 127.0.0.1:6379 and requires auth.
# Set REDIS_PASSWORD in docker/.env and use the same password here.
REDIS_URL=redis://:${REDIS_PASSWORD:-vidforge}@localhost:6379/0

# Auth
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM
# When running ollama via docker-compose, this must match OLLAMA_PORT in docker/.env
# (default 11435). Use 11434 only if you run ollama natively on the host.
OLLAMA_URL=http://localhost:11435

# Chat orchestration
# Maximum number of model/tool-call iterations per chat turn. Increase this if
# long multi-step conversations hit the iteration_limit_exceeded error.
CHAT_MAX_ITERATIONS=16

# ComfyUI
# When running via docker-compose, use http://comfyui:8188
# For local development, use http://localhost:8188
COMFYUI_URL=http://localhost:8188

# AudioCraft/MusicGen server URL
# When running via docker-compose, use http://audiocraft:5000
AUDIOCRAFT_URL=http://audiocraft:5050

# Storage (local, s3, ssh)
STORAGE_BACKEND=local
STORAGE_PATH=./storage

# S3 (if STORAGE_BACKEND=s3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1

# SSH (if STORAGE_BACKEND=ssh)
# SSH_HOST=
# SSH_USER=
# SSH_KEY_PATH=
# SSH_REMOTE_PATH=/var/lib/vidforge/storage
# SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts
# One-time setup: ssh-keyscan -H <SSH_HOST> >> ~/.ssh/known_hosts

# Preview settings
PREVIEW_WIDTH=854
PREVIEW_HEIGHT=480
PREVIEW_FPS=15
PREVIEW_QUALITY=28

# Debug
DEBUG=true

# Initial admin user (created on first startup)
# If ADMIN_PASSWORD is omitted, a random password is generated and logged once.
ADMIN_EMAIL=admin@vidforge.dev
# ADMIN_PASSWORD=set-me-or-leave-unset-for-random
