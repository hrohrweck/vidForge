# Database
DATABASE_URL=postgresql+asyncpg://vidforge:vidforge@localhost:5432/vidforge

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM
OLLAMA_URL=http://localhost:11434

# Storage (local, s3, ssh)
STORAGE_BACKEND=local
STORAGE_PATH=./storage

# S3 (if STORAGE_BACKEND=s3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1

# SSH (if STORAGE_BACKEND=ssh)
# SSH_HOST=
# SSH_USER=
# SSH_KEY_PATH=
# SSH_REMOTE_PATH=/var/lib/vidforge/storage

# Preview settings
PREVIEW_WIDTH=854
PREVIEW_HEIGHT=480
PREVIEW_FPS=15
PREVIEW_QUALITY=28

# Debug
DEBUG=true
